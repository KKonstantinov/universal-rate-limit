{
    "name": "@universal-rate-limit/hono",
    "version": "2.0.3",
    "description": "Hono middleware for universal-rate-limit",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=20"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsgo --noEmit",
        "test:integration": "vitest run test/integration",
        "release:jsr": "npx jsr publish --allow-dirty"
    },
    "dependencies": {
        "universal-rate-limit": "workspace:*"
    },
    "peerDependencies": {
        "hono": ">=4.0.0"
    },
    "devDependencies": {
        "hono": "^4.12.7"
    },
    "keywords": [
        "rate-limit",
        "middleware",
        "hono"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KKonstantinov/universal-rate-limit.git",
        "directory": "packages/middleware/hono"
    },
    "homepage": "https://universal-rate-limit.vercel.app",
    "bugs": {
        "url": "https://github.com/KKonstantinov/universal-rate-limit/issues"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "license": "MIT"
}
