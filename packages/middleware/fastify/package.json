{
    "name": "@universal-rate-limit/fastify",
    "version": "1.0.0",
    "description": "Fastify plugin for universal-rate-limit",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=20"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsgo --noEmit",
        "test:integration": "vitest run test/integration"
    },
    "dependencies": {
        "fastify-plugin": "^5.1.0",
        "universal-rate-limit": "workspace:*"
    },
    "peerDependencies": {
        "fastify": ">=4.0.0"
    },
    "devDependencies": {
        "fastify": "^5.8.2"
    },
    "keywords": [
        "rate-limit",
        "middleware",
        "fastify",
        "plugin"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KKonstantinov/universal-rate-limit.git",
        "directory": "packages/middleware/fastify"
    },
    "homepage": "https://github.com/KKonstantinov/universal-rate-limit/tree/main/packages/middleware/fastify#readme",
    "bugs": {
        "url": "https://github.com/KKonstantinov/universal-rate-limit/issues"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "license": "MIT"
}
