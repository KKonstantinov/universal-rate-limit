{
    "name": "@universal-rate-limit/monorepo",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.29.3",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "pnpm -r run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run --project tests/integration",
        "test:bun": "bun test tests/bun/",
        "test:deno": "deno test --allow-net tests/deno/",
        "test:all": "pnpm test && pnpm test:bun && pnpm test:deno",
        "typecheck": "pnpm -r run typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "changeset": "changeset",
        "version-packages": "changeset version && node scripts/sync-jsr-versions.js",
        "release": "pnpm build && changeset publish",
        "release:jsr": "cd packages/core && npx jsr publish --allow-dirty && cd ../../packages/middleware/hono && npx jsr publish --allow-dirty",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "prepare": "lefthook install"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.5.2",
        "@changesets/cli": "^2.29.8",
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.0.0",
        "@typescript/native-preview": "7.0.0-dev.20260228.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unicorn": "^63.0.0",
        "jiti": "^2.6.1",
        "lefthook": "^2.1.1",
        "prettier": "^3.8.1",
        "tsdown": "^0.20.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitepress": "^1.6.4",
        "vitest": "^3.0.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "lefthook"
        ]
    }
}
