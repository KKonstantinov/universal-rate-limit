{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": [
        "packages/core/src",
        "packages/core/test",
        "packages/core/*.config.ts",
        "packages/redis/src",
        "packages/redis/test",
        "packages/redis/*.config.ts",
        "packages/middleware/*/src",
        "packages/middleware/*/test",
        "packages/middleware/*/*.config.ts",
        "packages/benchmarks/src",
        "packages/benchmarks/*.config.ts",
        "packages/playground/src/**/*.ts",
        "packages/playground/src/**/*.tsx",
        "packages/playground/test",
        "packages/playground/*.config.ts",
        "examples/*/src",
        "examples/*/test",
        "examples/*/*.config.ts",
        "docs/.vitepress/theme",
        "*.config.ts"
    ],
    "exclude": ["node_modules", "**/dist", "**/node_modules"]
}
